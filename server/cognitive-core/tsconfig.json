{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "baseUrl": "../../",
    "paths": {
      "@shared/*": ["../shared/*"],
      "@server/*": ["../server/*"]
    }
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "dist"]
}