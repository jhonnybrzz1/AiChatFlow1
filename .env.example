# Database Configuration
DATABASE_URL=your_database_url_here

# Server Configuration
PORT=5000
NODE_ENV=development

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_DEFAULT=gpt-5.4-nano
OPENAI_MODEL_FAST=gpt-5.4-nano
OPENAI_MODEL_CAPABLE=gpt-5.4-nano

# Optional cost tracking overrides, in USD per 1M tokens.
# Use these when the selected model is not in the built-in pricing map.
OPENAI_INPUT_COST_USD_PER_1M=
OPENAI_OUTPUT_COST_USD_PER_1M=

# Local AI optimization controls
AI_RESPONSE_CACHE_ENABLED=true
AI_RESPONSE_CACHE_MAX_ENTRIES=250
AI_RESPONSE_CACHE_TTL_MS=1800000
AI_USAGE_MAX_RECORDS=1000
EVOLVING_CONTEXT_TTL_MS=3600000
EVOLVING_CONTEXT_MAX_ENTRIES=100

# GitHub Configuration
# Use a fine-grained personal access token with read-only repository permissions:
# - Repository access: selected repositories or all repositories
# - Contents: Read-only
# - Metadata: Read-only
GITHUB_ACCESS_TOKEN=your_fine_grained_read_only_github_token_here
GITHUB_TOKEN=your_fine_grained_read_only_github_token_here

# Session Configuration
SESSION_SECRET=your_session_secret_here
