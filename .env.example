# Database Configuration
DATABASE_URL=your_database_url_here

# Server Configuration
PORT=5000
NODE_ENV=development

# Mistral AI Configuration
MISTRAL_API_KEY=your_mistral_api_key_here

# GitHub Configuration
# Use a fine-grained personal access token with read-only repository permissions:
# - Repository access: selected repositories or all repositories
# - Contents: Read-only
# - Metadata: Read-only
GITHUB_ACCESS_TOKEN=your_fine_grained_read_only_github_token_here
GITHUB_TOKEN=your_fine_grained_read_only_github_token_here

# Session Configuration
SESSION_SECRET=your_session_secret_here
